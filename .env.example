# Copy this file to .env and fill in HUAWEI_HOST and VICTRON_HOST before running docker compose up.
# cp .env.example .env

# Required — set to your hardware IP addresses
HUAWEI_HOST=192.168.0.10
VICTRON_HOST=192.168.0.20

# InfluxDB — token must match DOCKER_INFLUXDB_INIT_ADMIN_TOKEN exactly
INFLUXDB_TOKEN=ems-dev-token-change-me
INFLUXDB_ORG=ems
INFLUXDB_BUCKET=ems
# INFLUXDB_URL is set automatically by docker-compose.yml (http://influxdb:8086)

# InfluxDB init (first-start only — ignored after data dir exists)
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=adminpassword
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=ems-dev-token-change-me

# Optional — defaults shown
# LOG_LEVEL=INFO
# HUAWEI_PORT=502
# VICTRON_PORT=1883
